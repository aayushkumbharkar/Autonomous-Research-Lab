GROQ_API_KEY=your_groq_api_key_here
# For contract testing with Specmatic stub: set to http://localhost:9000
GROQ_BASE_URL=https://api.groq.com/openai/v1

OPENAI_API_KEY=your_openai_api_key_here  # if used
DATABASE_URL=sqlite:///./veritas.db
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Veritas application configurations
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_URL=sqlite+aiosqlite:///./data/research_lab.db
LOG_LEVEL=INFO
EVAL_THRESHOLD=0.7
MAX_RETRY_ATTEMPTS=3
GROQ_MODEL=openai/gpt-oss-20b
WHISPER_MODEL=whisper-large-v3-turbo
FRONTEND_URL=http://localhost:5173
PORT=8000
CONTRACT_TEST_MODE=false
